# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DATABASE_NAME=news_pulse

# Python Service
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_PORT=8000

# Backend API
BACKEND_PORT=5000
BACKEND_API_URL=http://localhost:5000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# News Sources (comma separated)
RSS_SOURCES=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.npr.org/1001/rss.xml,https://www.theguardian.com/world/rss

# Clustering Parameters
# How many shared keywords = related?
CLUSTER_THRESHOLD=3
# Minimum word length to consider as keyword
MIN_WORD_LENGTH=3